# CP Migration Tool — Production environment template
# Copy to /opt/cp_migration_tool/apps/web/.env
# NEVER commit real values to version control

DATABASE_URL=file:./data/dev.db
AUTH_USERNAME=admin
AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SESSION_SECRET=CHANGE_ME_MIN_32_CHARACTERS_RANDOM_STRING
# CONFIG_PIN=optional-pin
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25
LOG_LEVEL=info
NODE_ENV=production
