# =============================================================================
# CP Migration Tool — Environment Variables
# Copy to .env and adjust. Never commit .env to version control.
# For passwords with $ & ! etc, use quotes: AUTH_PASSWORD='MyPass$123'
# SESSION_SECRET must be at least 32 characters in production.
# =============================================================================

DATABASE_URL=file:./data/dev.db
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
SESSION_SECRET=your-secret-key-minimum-32-characters-long
# COOKIE_SECURE=false   # Set for HTTP (no HTTPS); uncomment for remote VM
# CONFIG_PIN=1234
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25
LOG_LEVEL=info
NODE_ENV=development
