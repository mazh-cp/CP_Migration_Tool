# =============================================================================
# CP Migration Tool — Environment Variables
# Copy to .env and adjust. Never commit .env to version control.
# For passwords with $ & ! etc, use quotes: AUTH_PASSWORD='MyPass$123'
# =============================================================================

DATABASE_URL=file:./data/dev.db
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
SESSION_SECRET=your-secret-key-min-32-chars
# CONFIG_PIN=1234
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25
LOG_LEVEL=info
NODE_ENV=development
