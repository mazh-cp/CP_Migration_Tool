# =============================================================================
# CP Migration Tool — Environment Variables
# Copy to apps/web/.env and adjust values. Never commit .env to version control.
# =============================================================================

# --- Database ---
DATABASE_URL=file:./data/dev.db

# --- Authentication ---
# Admin login. Create additional users via Settings.
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# --- Session (REQUIRED in production) ---
# JWT signing secret. Must be at least 32 characters.
SESSION_SECRET=your-secret-key-min-32-chars

# --- Config Protection (optional) ---
# CONFIG_PIN=1234

# --- File Upload ---
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25

# --- Logging ---
LOG_LEVEL=info

# --- Application ---
NODE_ENV=development
